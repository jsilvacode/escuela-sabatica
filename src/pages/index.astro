---
import BaseLayout from "@components/layout/BaseLayout.astro";
import PageHero from "@components/layout/PageHero.astro";
import LessonCard from "@components/lesson/LessonCard.astro";
import { ManuscriptReader } from "@components/lesson/ManuscriptReader";
import { getQuarter } from "@lib/lessonAdapter";

const quarter = getQuarter();
---

<BaseLayout title="Escuela Sabática | Inicio" activeSection="home">
  <div class="content-wrap">
    <PageHero
      variant="home"
      quarter={quarter}
      subtitle={quarter.keyVerse?.text + " — " + quarter.keyVerse?.reference.display}
    />

    <section class="manuscript" aria-label="Resumen del trimestre">
      <div class="manuscript-inner">
        <h2>Introducción</h2>
        <h3 class="manuscript-subtitle">Primera y Segunda a los Corintios</h3>
        {quarter.description.split("\n\n").slice(0, -1).map((paragraph) => (
          <ManuscriptReader text={paragraph.trim()} client:load />
        ))}
        <p class="manuscript-author">{quarter.description.split("\n\n").pop()?.trim()}</p>
      </div>
    </section>

    <section aria-labelledby="lessons-heading">
      <div class="section-heading">
        <h2 id="lessons-heading" class="lessons-title">Lecciones del trimestre</h2>
      </div>
      <div class="lessons-grid">
        {quarter.lessons.map((lesson) => <LessonCard lesson={lesson} active={lesson.number === 1} />)}
      </div>
    </section>
  </div>
</BaseLayout>
