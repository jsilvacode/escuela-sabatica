---
import BaseLayout from "@components/layout/BaseLayout.astro";
import PageHero from "@components/layout/PageHero.astro";
import DayTabs from "@components/lesson/DayTabs.astro";
import { DailyReading } from "@components/lesson/DailyReading";
import { AudioPlayer } from "@components/audio/AudioPlayer";
import StudySidebar from "@components/layout/StudySidebar.astro";
import { getAdjacentDay, getDay, getLesson, getLessons, getQuarter } from "@lib/lessonAdapter";
import reavivadosRaw from "@data/quarters/2026-q3.json";

const reavivadosEntries = (reavivadosRaw as any).reavivados ?? [];

const reavivadosByDate: Record<string, { reading: string; bookId?: number; chapter?: number }> = {};
for (const e of reavivadosEntries) {
  reavivadosByDate[e.date] = { reading: e.reading, bookId: (e as any).bookId, chapter: (e as any).chapter };
}

export function getStaticPaths() {
  return getLessons().filter(l => l.days.length > 0).flatMap((lesson) =>
    lesson.days.map((day) => ({
      params: { lessonId: lesson.id, dayId: day.id },
    })),
  );
}

const { lessonId, dayId } = Astro.params;
const lesson = getLesson(lessonId ?? "");
const day = lesson ? getDay(lesson.id, dayId ?? "") : undefined;
const quarter = getQuarter();

if (!lesson || !day) {
  return Astro.redirect("/");
}

const months = ["", "enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];

function formatDate(dateStr: string) {
  if (!dateStr) return "";
  const [y, m, d] = dateStr.split("-");
  return `${parseInt(d)} de ${months[parseInt(m)]}`;
}

function formatEndDate(dateStr: string) {
  if (!dateStr) return "";
  const [y, m, d] = dateStr.split("-");
  return `${parseInt(d)} de ${months[parseInt(m)]}`;
}

const dayLabel = `${day.dayName} ${formatDate(day.date ?? "")}`;
const heroEyebrow = `Lección ${lesson.number}, para el ${formatEndDate(lesson.endDate ?? "")}`;
const previousDay = getAdjacentDay(lesson, day.id, -1);
const nextDay = getAdjacentDay(lesson, day.id, 1);
---

<BaseLayout title={`${day.title} | ${lesson.title}`} activeSection="lessons">
  <div class="content-wrap">
    <PageHero
      variant="lesson"
      title={lesson.title}
      image={lesson.image}
      eyebrow={heroEyebrow}
      subtitle={lesson.summary}
    />

    <div class="daily-layout">
      <div>
        <nav class="breadcrumb" aria-label="Ruta">
          <a href="/">Inicio</a>
          <span>›</span>
          <span>{lesson.title}</span>
          <span>›</span>
          <span>{dayLabel}</span>
        </nav>

        <h1 class="daily-title">{day.title}</h1>
        {day.image && <img class="daily-image" src={day.image} alt={`Imagen de lectura: ${day.title}`} />}
        <DayTabs lesson={lesson} activeDayId={day.id} compact />
        <AudioPlayer client:load audio={day.audio} />
        <DailyReading client:load lesson={lesson} day={day} previousDay={previousDay} nextDay={nextDay} />
      </div>

      <StudySidebar lesson={lesson} activeDay={day} />
    </div>
  </div>
</BaseLayout>

<div id="day-data" data-reavivados={JSON.stringify(reavivadosByDate)} data-lesson-days={JSON.stringify(lesson.days.map(d => ({id:d.id, date:d.date, dayName:d.dayName})))} hidden></div>

<script is:inline>
  var __dayData = document.getElementById("day-data");
  var __reavivadosByDate = JSON.parse(__dayData.getAttribute("data-reavivados") || "{}");
  var __lessonDays = JSON.parse(__dayData.getAttribute("data-lesson-days") || "[]");

  function updateDayUI(dayId) {
    // Update DayTabs
    document.querySelectorAll(".compact-day, .day-tab").forEach(function (el) {
      el.classList.toggle("active", el.getAttribute("href") && el.getAttribute("href").endsWith("/" + dayId));
      el.setAttribute("aria-current", el.classList.contains("active") ? "page" : "false");
    });
    var sel = document.querySelector(".day-select");
    if (sel) {
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value.endsWith("/" + dayId)) { sel.selectedIndex = i; break; }
      }
    }
    // Update StudySidebar: Reavivados widget
    var dayData = __lessonDays.find(function(d) { return d.id === dayId; });
    if (dayData && dayData.date) {
      var rr = __reavivadosByDate[dayData.date];
      var widget = document.getElementById("reavivados-widget");
      if (widget && rr) {
        var readingEl = widget.querySelector(".reavivados-reading");
        var linkEl = widget.querySelector(".reavivados-button");
        if (readingEl) readingEl.textContent = rr.reading;
        if (linkEl && rr.bookId && rr.chapter) {
          linkEl.href = "https://www.santabiblia.cloud/read/" + rr.bookId + "/" + rr.chapter;
          linkEl.style.display = "";
        } else if (linkEl) {
          linkEl.style.display = "none";
        }
        var fallbackEl = widget.querySelector(".reavivados-card");
        if (fallbackEl) fallbackEl.style.display = rr ? "none" : "";
      }
    }
  }

  var origNavigate = window.__navigateToDay;
  window.__navigateToDay = function(dayId) {
    if (origNavigate) origNavigate(dayId);
    updateDayUI(dayId);
    document.getElementById("audio")?.scrollIntoView({ behavior: "smooth", block: "start" });
  };

  // Intercept clicks on day tabs
  document.addEventListener("click", function (e) {
    var link = e.target.closest("a[href*='/lecciones/']");
    if (!link) return;
    var href = link.getAttribute("href");
    if (!href) return;
    var match = href.match(/\/lecciones\/([^/]+)\/([^/]+)/);
    if (!match) return;
    e.preventDefault();
    if (window.__navigateToDay) window.__navigateToDay(match[2]);
  });
</script>
