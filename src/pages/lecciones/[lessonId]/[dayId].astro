---
import BaseLayout from "@components/layout/BaseLayout.astro";
import PageHero from "@components/layout/PageHero.astro";
import DayTabs from "@components/lesson/DayTabs.astro";
import { DailyReading } from "@components/lesson/DailyReading";
import { AudioPlayer } from "@components/audio/AudioPlayer";
import StudySidebar from "@components/layout/StudySidebar.astro";
import { getAdjacentDay, getDay, getLesson, getLessons, getQuarter } from "@lib/lessonAdapter";

export function getStaticPaths() {
  return getLessons().filter(l => l.days.length > 0).flatMap((lesson) =>
    lesson.days.map((day) => ({
      params: { lessonId: lesson.id, dayId: day.id },
    })),
  );
}

const { lessonId, dayId } = Astro.params;
const lesson = getLesson(lessonId ?? "");
const day = lesson ? getDay(lesson.id, dayId ?? "") : undefined;
const quarter = getQuarter();

if (!lesson || !day) {
  return Astro.redirect("/");
}

const months = ["", "enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];

function formatDate(dateStr: string) {
  if (!dateStr) return "";
  const [y, m, d] = dateStr.split("-");
  return `${parseInt(d)} de ${months[parseInt(m)]}`;
}

function formatEndDate(dateStr: string) {
  if (!dateStr) return "";
  const [y, m, d] = dateStr.split("-");
  return `${parseInt(d)} de ${months[parseInt(m)]}`;
}

const dayLabel = `${day.dayName} ${formatDate(day.date ?? "")}`;
const heroEyebrow = `Lección ${lesson.number}, para el ${formatEndDate(lesson.endDate ?? "")}`;
const previousDay = getAdjacentDay(lesson, day.id, -1);
const nextDay = getAdjacentDay(lesson, day.id, 1);
---

<BaseLayout title={`${day.title} | ${lesson.title}`} activeSection="lessons">
  <div class="content-wrap">
    <PageHero
      variant="lesson"
      title={lesson.title}
      image={lesson.image}
      eyebrow={heroEyebrow}
      subtitle={lesson.summary}
    />

    <div class="daily-layout">
      <div>
        <nav class="breadcrumb" aria-label="Ruta">
          <a href="/">Inicio</a>
          <span>›</span>
          <span>{lesson.title}</span>
          <span>›</span>
          <span>{dayLabel}</span>
        </nav>

        <h1 class="daily-title">{day.title}</h1>
        {day.image && <img class="daily-image" src={day.image} alt={`Imagen de lectura: ${day.title}`} />}
        <DayTabs lesson={lesson} activeDayId={day.id} compact />
        <AudioPlayer client:load audio={day.audio} />
        <DailyReading client:load lesson={lesson} day={day} previousDay={previousDay} nextDay={nextDay} />
      </div>

      <StudySidebar lesson={lesson} activeDay={day} />
    </div>
  </div>
</BaseLayout>

<script is:inline>
  // Intercept clicks on day tabs and use client-side navigation (no page reload)
  document.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest("a[href*='/lecciones/']");
    if (!link) return;
    const href = link.getAttribute("href");
    if (!href) return;
    const match = href.match(/\/lecciones\/([^/]+)\/([^/]+)/);
    if (!match) return;
    e.preventDefault();
    const dayId = match[2];
    const navFn = (window as any).__navigateToDay;
    if (navFn) navFn(dayId);
  });
</script>
