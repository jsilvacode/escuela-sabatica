---
import type { Lesson, LessonDay } from "@app-types/lesson";
import reavivadosData from "@data/quarters/2026-q3.json";

type Props = {
  lesson: Lesson;
  activeDay?: LessonDay;
};

const { lesson, activeDay } = Astro.props;
const lessonResources = lesson.resources ?? [];
const pptResources = lessonResources.filter(r => r.type === "ppt");
const pdfResources = lessonResources.filter(r => r.type === "pdf");

const todayReading = activeDay?.date
  ? reavivadosData.reavivados?.find((r: { date: string }) => r.date === activeDay.date)
  : null;

const reavivadosReading = todayReading?.reading ?? null;
const reavivadosBookId = todayReading && "bookId" in todayReading ? (todayReading as any).bookId : null;
const reavivadosChapter = todayReading && "chapter" in todayReading ? (todayReading as any).chapter : null;
const reavivadosUrl = reavivadosBookId && reavivadosChapter
  ? `https://www.santabiblia.cloud/read/${reavivadosBookId}/${reavivadosChapter}`
  : null;

const dayAbbr: Record<string, string> = {
  Sábado: "Sáb", Domingo: "Dom", Lunes: "Lun", Martes: "Mar",
  Miércoles: "Mié", Jueves: "Jue", Viernes: "Vie",
};
---

<aside class="right-rail" aria-label="Material complementario">
  <!-- 1. Elena de White -->
  <section class="study-widget">
    <h3>Notas de Elena G. de White</h3>
    {lesson.egwNotes ? (
      <>
        <p class="egw-text">{lesson.egwNotes}</p>
        <div class="egw-source">
          <a class="ghost-button" href={`/lecciones/${lesson.id}/viernes`}>
            Leer completo en Viernes →
          </a>
        </div>
      </>
    ) : (
      <p class="muted">Notas complementarias pronto disponibles.</p>
    )}
  </section>

  <!-- 2. Material de la semana (PPT) -->
  <section class="study-widget">
    <h3>Material de la semana</h3>
    {pptResources.length > 0 ? (
      <div class="resource-sidebar-list">
        {pptResources.map((resource) => (
          <a
            class={resource.url && resource.url !== "#" ? "sidebar-ppt-card" : "sidebar-ppt-card ppt-unavailable"}
            href={resource.url && resource.url !== "#" ? resource.url : undefined}
            {...(resource.url && resource.url !== "#" ? { download: true } : {})}
          >
            <span class="sidebar-ppt-cover">
              <img src="/images/covers/ppt-cover.svg" alt="PPT" width="72" height="88" loading="lazy" />
            </span>
            <strong class="sidebar-ppt-title">{resource.title}</strong>
            <span class="sidebar-ppt-action">
              {resource.url && resource.url !== "#" ? "Descargar ↓" : "Próximamente"}
            </span>
          </a>
        ))}
        {pdfResources.map((resource) => (
          <a
            class="sidebar-ppt-card"
            href={resource.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="sidebar-ppt-cover">
              <img src="/images/covers/pdf-cover.svg" alt="PDF" width="72" height="88" loading="lazy" />
            </span>
            <strong class="sidebar-ppt-title">PDF de la lección</strong>
            <span class="sidebar-ppt-action">Descargar en Adventech →</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="muted">Sin material para esta lección.</p>
    )}
  </section>

  <!-- 3. Reavivados por su Palabra -->
  <section class="study-widget">
    <h3>Reavivados por su Palabra</h3>
    {reavivadosUrl ? (
      <a class="reavivados-button" href={reavivadosUrl} target="_blank" rel="noopener noreferrer">
        <span class="reavivados-label">Lectura de hoy</span>
        <span class="reavivados-reading">{reavivadosReading}</span>
        <span class="reavivados-cta">Leer en Santa Biblia →</span>
      </a>
    ) : (
      <div class="reavivados-card">
        <span class="reavivados-icon" aria-hidden="true">📖</span>
        <div>
          <strong>Lectura de hoy</strong>
          <p>{reavivadosReading ?? "Consulta el plan de lectura"}</p>
        </div>
      </div>
    )}
  </section>

  <section class="study-widget">
    <a class="resource-all-link" href="/recursos">
      Todos los recursos →
    </a>
  </section>
</aside>
