---
import type { Lesson } from "@app-types/lesson";

type Props = {
  lesson: Lesson;
  activeDayId?: string;
  compact?: boolean;
};

const { lesson, activeDayId = lesson.days[0]?.id, compact = false } = Astro.props;
---

<nav class={compact ? "compact-days" : "day-tabs"} aria-label="Días de la lección">
  {
    lesson.days.map((day, index) => (
      <a
        class:list={[compact ? "compact-day" : "day-tab", { active: day.id === activeDayId }]}
        href={`/lecciones/${lesson.id}/${day.id}`}
        aria-current={day.id === activeDayId ? "page" : undefined}
      >
        {compact ? (
          <>
            Día {index + 1}
            <span>{day.dayName}</span>
          </>
        ) : (
          day.dayName
        )}
      </a>
    ))
  }
</nav>

<select class="day-select" aria-label="Seleccionar día" onchange="var m=this.value.match(/lecciones\/([^/]+)\/([^/]+)/);if(m&&window.__navigateToDay)window.__navigateToDay(m[2])">
  {
    lesson.days.map((day, index) => (
      <option
        value={`/lecciones/${lesson.id}/${day.id}`}
        selected={day.id === activeDayId}
      >
        Día {index + 1} — {day.dayName}
      </option>
    ))
  }
</select>
